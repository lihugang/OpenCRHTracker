{
    "$schema": "../assets/json/configScheme.json",
    "spider": {
        "userAgent": "Mozilla/5.0 (iPhone; CPU iPhone OS 14_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Mobile/15E148 MicroMessenger/7.0.17(0x17001126) NetType/WIFI Language/zh_CN",
        "params": {
            "eKey": "OpenCRHTracker",
            "jsonpCallback": "OpenCRHTracker",
            "routeProbeCarCode": "CR400AF-C-2214"
        },
        "rateLimit": {
            "query": {
                "minIntervalMs": 1500
            },
            "search": {
                "minIntervalMs": 8000
            }
        },
        "scheduleProbe": {
            "dailyTimeHHmm": "0000",
            "retryAttempts": 3,
            "maxBatchSize": 200,
            "checkpointFlushEvery": 20,
            "refresh": {
                "batchSize": 20,
                "ttlHours": 24,
                "generateIntervalHours": 24
            },
            "probe": {
                "defaultRetry": 5
            },
            "coupling": {
                "candidateCap": 200,
                "reuseWithinSeconds": 3600,
                "runningGraceSeconds": 900,
                "statusResetTimeHHmm": "0000",
                "detectDelaySeconds": 900,
                "detectCooldownSeconds": 1800
            },
            "prefixRules": [
                {
                    "prefix": "G",
                    "minNo": 1,
                    "maxNo": 9999
                },
                {
                    "prefix": "D",
                    "minNo": 1,
                    "maxNo": 9999
                },
                {
                    "prefix": "C",
                    "minNo": 1,
                    "maxNo": 9999
                }
            ]
        }
    },
    "data": {
        "assets": {
            "EMUList": {
                "file": "data/emu_list.jsonl",
                "provider": "https://storage.lihugang.top/open_crh_tracker/initialized_data/emu_list.jsonl",
                "refresh": {
                    "enabled": true,
                    "refreshAt": "0000"
                }
            },
            "QRCode": {
                "file": "data/qrcode.jsonl",
                "provider": "https://storage.lihugang.top/open_crh_tracker/initialized_data/qrcode.jsonl",
                "refresh": {
                    "enabled": true,
                    "refreshAt": "0000"
                }
            },
            "schedule": {
                "file": "data/schedule.json",
                "provider": "https://storage.lihugang.top/open_crh_tracker/initialized_data/schedule.json"
            }
        },
        "databases": {
            "task": "data/task.db",
            "EMUTracked": "data/emu.db",
            "users": "data/users.db"
        }
    },
    "user": {
        "saltLength": 16,
        "apiKeyPrefix": "ocrh_",
        "apiKeyBytes": 24,
        "apiKeyTtlSeconds": 2592000,
        "scrypt": {
            "keyLength": 64,
            "cost": 16384,
            "blockSize": 8,
            "parallelization": 1
        }
    },
    "api": {
        "versionPrefix": "/api/v1",
        "apiKeyHeader": "x-api-key",
        "headers": {
            "remain": "remain",
            "cost": "cost",
            "retryAfter": "Retry-After"
        },
        "cache": {
            "searchIndexMaxAgeSeconds": 1800
        },
        "pagination": {
            "defaultLimit": 20,
            "maxLimit": 200
        },
        "timestampUnit": "seconds",
        "debug": {
            "enableEchoError": true
        }
    },
    "task": {
        "startup": {
            "disabledExecutors": []
        },
        "scheduler": {
            "pollIntervalMs": 180000,
            "maxTasksPerQuery": 50,
            "idle": {
                "maxTasksPerTick": 4,
                "emaAlpha": 0.3
            }
        }
    },
    "quota": {
        "anonymousMaxTokens": 20,
        "userMaxTokens": 1000,
        "refillAmount": 100,
        "refillIntervalSeconds": 3600,
        "resetToMaxOnRestart": true
    },
    "cost": {
        "fixed": {
            "health": 0,
            "quotaMe": 1,
            "debugEchoError": 0,
            "authLogin": 2,
            "authIssueApiKey": 10,
            "authListApiKeys": 2,
            "authRevokeApiKey": 1,
            "searchIndex": 1,
            "exportDaily": 100
        },
        "perRecord": {
            "historyEmu": {
                "unitCost": 0.05,
                "rounding": "ceil"
            },
            "historyTrain": {
                "unitCost": 0.05,
                "rounding": "ceil"
            },
            "recordsDaily": {
                "unitCost": 0.05,
                "rounding": "ceil"
            }
        }
    }
}
