{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "QRCode Detection Scheme",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "minLength": 1
        },
        "detectedAt": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "pattern": "^\\d{4}$"
            }
        },
        "emu": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "minLength": 1
            }
        }
    },
    "required": [
        "detectedAt",
        "emu"
    ]
}
