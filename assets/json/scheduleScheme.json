{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Schedule Scheme",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "const": "../assets/json/scheduleScheme.json"
        },
        "version": {
            "type": "integer",
            "const": 4
        },
        "published": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "#/definitions/scheduleState"
                }
            ]
        },
        "building": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "#/definitions/scheduleState"
                }
            ]
        }
    },
    "definitions": {
        "prefixRule": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "prefix": {
                    "type": "string",
                    "minLength": 1
                },
                "minNo": {
                    "type": "integer",
                    "minimum": 1
                },
                "maxNo": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "prefix",
                "minNo",
                "maxNo"
            ]
        },
        "progressCounters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "apiCalls": {
                    "type": "integer",
                    "minimum": 0
                },
                "apiRetries": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "required": [
                "apiCalls",
                "apiRetries"
            ]
        },
        "scheduleStop": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "stationNo": {
                    "type": "integer",
                    "minimum": 1
                },
                "stationName": {
                    "type": "string",
                    "minLength": 1
                },
                "arriveAt": {
                    "description": "Second offset from schedule.date 00:00:00 Asia/Shanghai",
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "departAt": {
                    "description": "Second offset from schedule.date 00:00:00 Asia/Shanghai",
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "stationTrainCode": {
                    "type": "string"
                },
                "wicket": {
                    "type": "string"
                },
                "isStart": {
                    "type": "boolean"
                },
                "isEnd": {
                    "type": "boolean"
                }
            },
            "required": [
                "stationNo",
                "stationName",
                "arriveAt",
                "departAt",
                "stationTrainCode",
                "wicket",
                "isStart",
                "isEnd"
            ]
        },
        "scheduleItem": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "code": {
                    "type": "string",
                    "minLength": 1
                },
                "internalCode": {
                    "type": "string"
                },
                "allCodes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "minItems": 1
                },
                "bureauCode": {
                    "type": "string"
                },
                "trainDepartment": {
                    "type": "string"
                },
                "passengerDepartment": {
                    "type": "string"
                },
                "startStation": {
                    "type": "string"
                },
                "endStation": {
                    "type": "string"
                },
                "startAt": {
                    "description": "Second offset from schedule.date 00:00:00 Asia/Shanghai",
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "endAt": {
                    "description": "Second offset from schedule.date 00:00:00 Asia/Shanghai; cross-day may be > 86399",
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "lastRouteRefreshAt": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "stops": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/scheduleStop"
                    }
                }
            },
            "required": [
                "code",
                "internalCode",
                "allCodes",
                "bureauCode",
                "trainDepartment",
                "passengerDepartment",
                "startStation",
                "endStation",
                "startAt",
                "endAt",
                "lastRouteRefreshAt",
                "stops"
            ]
        },
        "scheduleStats": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "rawItems": {
                    "type": "integer",
                    "minimum": 0
                },
                "uniqueItems": {
                    "type": "integer",
                    "minimum": 0
                },
                "durationMs": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "required": [
                "rawItems",
                "uniqueItems",
                "durationMs"
            ]
        },
        "scheduleState": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "date": {
                    "type": "string",
                    "minLength": 1
                },
                "lastBuildDate": {
                    "type": "string",
                    "minLength": 0
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "running",
                        "done",
                        "partial_failed"
                    ]
                },
                "strategy": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "retryAttempts": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "maxBatchSize": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "checkpointFlushEvery": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": [
                        "retryAttempts",
                        "maxBatchSize",
                        "checkpointFlushEvery"
                    ]
                },
                "scope": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "prefixRules": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/prefixRule"
                            }
                        }
                    },
                    "required": [
                        "prefixRules"
                    ]
                },
                "progress": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "phase": {
                            "type": "string",
                            "enum": [
                                "discover",
                                "enrich",
                                "done"
                            ]
                        },
                        "discoverMode": {
                            "type": "string",
                            "enum": [
                                "full",
                                "retry"
                            ]
                        },
                        "discoverQueue": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "discoverProcessed": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "enrichCursor": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "failedKeywords": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "failedEnrichCodes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "counters": {
                            "$ref": "#/definitions/progressCounters"
                        }
                    },
                    "required": [
                        "phase",
                        "discoverMode",
                        "discoverQueue",
                        "discoverProcessed",
                        "enrichCursor",
                        "failedKeywords",
                        "failedEnrichCodes",
                        "counters"
                    ]
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/scheduleItem"
                    }
                },
                "stats": {
                    "$ref": "#/definitions/scheduleStats"
                },
                "startedAtMs": {
                    "type": "integer",
                    "minimum": 0
                },
                "generatedAt": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "required": [
                "date",
                "lastBuildDate",
                "status",
                "strategy",
                "scope",
                "progress",
                "items",
                "stats",
                "startedAtMs",
                "generatedAt"
            ]
        }
    },
    "required": [
        "$schema",
        "version",
        "published",
        "building"
    ]
}
