{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Config Scheme",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "minLength": 1
        },
        "spider": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "userAgent": {
                    "type": "string",
                    "minLength": 1
                },
                "params": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "eKey": {
                            "type": "string",
                            "minLength": 1
                        },
                        "jsonpCallback": {
                            "type": "string",
                            "minLength": 1
                        },
                        "routeProbeCarCode": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "required": [
                        "eKey",
                        "jsonpCallback",
                        "routeProbeCarCode"
                    ]
                },
                "rateLimit": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "query": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "minIntervalMs": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "required": [
                                "minIntervalMs"
                            ]
                        },
                        "search": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "minIntervalMs": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "required": [
                                "minIntervalMs"
                            ]
                        }
                    },
                    "required": [
                        "query",
                        "search"
                    ]
                },
                "scheduleProbe": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "dailyTimeHHmm": {
                            "type": "string",
                            "pattern": "^\\d{4}$"
                        },
                        "retryAttempts": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "maxBatchSize": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "checkpointFlushEvery": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "refresh": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "batchSize": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "ttlHours": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "generateIntervalHours": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "batchSize",
                                "ttlHours",
                                "generateIntervalHours"
                            ]
                        },
                        "probe": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "defaultRetry": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "overlapRetryDelaySeconds": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "required": [
                                "defaultRetry",
                                "overlapRetryDelaySeconds"
                            ]
                        },
                        "coupling": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "candidateCap": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "runningGraceSeconds": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "statusResetTimeHHmm": {
                                    "type": "string",
                                    "pattern": "^\\d{4}$"
                                },
                                "detectDelaySeconds": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "detectCooldownSeconds": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "required": [
                                "candidateCap",
                                "runningGraceSeconds",
                                "statusResetTimeHHmm",
                                "detectDelaySeconds",
                                "detectCooldownSeconds"
                            ]
                        },
                        "prefixRules": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                    "prefix": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "minNo": {
                                        "type": "integer",
                                        "minimum": 1
                                    },
                                    "maxNo": {
                                        "type": "integer",
                                        "minimum": 1
                                    }
                                },
                                "required": [
                                    "prefix",
                                    "minNo",
                                    "maxNo"
                                ]
                            }
                        }
                    },
                    "required": [
                        "dailyTimeHHmm",
                        "retryAttempts",
                        "maxBatchSize",
                        "checkpointFlushEvery",
                        "refresh",
                        "probe",
                        "coupling",
                        "prefixRules"
                    ]
                }
            },
            "required": [
                "userAgent",
                "params",
                "rateLimit",
                "scheduleProbe"
            ]
        },
        "data": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "assets": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "EMUList": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "file": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "provider": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "refresh": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "enabled": {
                                            "type": "boolean"
                                        },
                                        "refreshAt": {
                                            "type": "string",
                                            "minLength": 1
                                        }
                                    }
                                }
                            },
                            "required": [
                                "file"
                            ]
                        },
                        "QRCode": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "file": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "provider": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "refresh": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "enabled": {
                                            "type": "boolean"
                                        },
                                        "refreshAt": {
                                            "type": "string",
                                            "minLength": 1
                                        }
                                    }
                                }
                            },
                            "required": [
                                "file"
                            ]
                        },
                        "schedule": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "file": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "provider": {
                                    "type": "string",
                                    "minLength": 1
                                }
                            },
                            "required": [
                                "file"
                            ]
                        }
                    },
                    "required": [
                        "EMUList",
                        "QRCode",
                        "schedule"
                    ]
                },
                "databases": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "task": {
                            "type": "string",
                            "minLength": 1
                        },
                        "EMUTracked": {
                            "type": "string",
                            "minLength": 1
                        },
                        "users": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "required": [
                        "task",
                        "EMUTracked",
                        "users"
                    ]
                }
            },
            "required": [
                "assets",
                "databases"
            ]
        },
        "user": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "saltLength": {
                    "type": "integer",
                    "minimum": 8
                },
                "apiKeyPrefixes": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "webapp": {
                            "type": "string",
                            "minLength": 1
                        },
                        "api": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "required": [
                        "webapp",
                        "api"
                    ]
                },
                "apiKeyBytes": {
                    "type": "integer",
                    "minimum": 16
                },
                "apiKeyTtlSeconds": {
                    "type": "integer",
                    "minimum": 60
                },
                "apiKeyMaxLifetimeSeconds": {
                    "type": "integer",
                    "minimum": 60
                },
                "signKey": {
                    "type": "string",
                    "minLength": 1
                },
                "scrypt": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "keyLength": {
                            "type": "integer",
                            "minimum": 16
                        },
                        "cost": {
                            "type": "integer",
                            "minimum": 2
                        },
                        "blockSize": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "parallelization": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": [
                        "keyLength",
                        "cost",
                        "blockSize",
                        "parallelization"
                    ]
                }
            },
            "required": [
                "saltLength",
                "apiKeyPrefixes",
                "apiKeyBytes",
                "apiKeyTtlSeconds",
                "scrypt"
            ]
        },
        "api": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "versionPrefix": {
                    "type": "string",
                    "minLength": 1
                },
                "apiKeyHeader": {
                    "type": "string",
                    "minLength": 1
                },
                "authCookieName": {
                    "type": "string",
                    "minLength": 1
                },
                "authRateLimit": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "login": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "maxRequests": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "windowSeconds": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "maxRequests",
                                "windowSeconds"
                            ]
                        },
                        "register": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "maxRequests": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "windowSeconds": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "maxRequests",
                                "windowSeconds"
                            ]
                        }
                    },
                    "required": [
                        "login",
                        "register"
                    ]
                },
                "authCache": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "userRecord": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "maxEntries": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "defaultTtlSeconds": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "maxEntries",
                                "defaultTtlSeconds"
                            ]
                        },
                        "apiKeyRecord": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "maxEntries": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "defaultTtlSeconds": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "maxEntries",
                                "defaultTtlSeconds"
                            ]
                        }
                    },
                    "required": [
                        "userRecord",
                        "apiKeyRecord"
                    ]
                },
                "payload": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "maxStringLength": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": [
                        "maxStringLength"
                    ]
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "remain": {
                            "type": "string",
                            "minLength": 1
                        },
                        "cost": {
                            "type": "string",
                            "minLength": 1
                        },
                        "retryAfter": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "required": [
                        "remain",
                        "cost",
                        "retryAfter"
                    ]
                },
                "cache": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "currentDayMaxAgeSeconds": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "historicalMaxAgeSeconds": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "searchIndexMaxAgeSeconds": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "currentDayMaxAgeSeconds",
                        "historicalMaxAgeSeconds",
                        "searchIndexMaxAgeSeconds"
                    ]
                },
                "pagination": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "defaultLimit": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "maxLimit": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": [
                        "defaultLimit",
                        "maxLimit"
                    ]
                },
                "timestampUnit": {
                    "type": "string",
                    "enum": [
                        "seconds"
                    ]
                },
                "debug": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "enableEchoError": {
                            "type": "boolean"
                        }
                    },
                    "required": [
                        "enableEchoError"
                    ]
                },
                "permissions": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "anonymousScopes": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "minLength": 1
                            }
                        },
                        "issuedKeyDefaultScopes": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "minLength": 1
                            }
                        },
                        "creatableKeyMaxScopes": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "minLength": 1
                            }
                        }
                    },
                    "required": [
                        "anonymousScopes",
                        "issuedKeyDefaultScopes",
                        "creatableKeyMaxScopes"
                    ]
                }
            },
            "required": [
                "versionPrefix",
                "apiKeyHeader",
                "authCookieName",
                "authRateLimit",
                "authCache",
                "payload",
                "headers",
                "cache",
                "pagination",
                "timestampUnit",
                "debug",
                "permissions"
            ]
        },
        "task": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "startup": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "disabledExecutors": {
                            "type": "array",
                            "uniqueItems": true,
                            "items": {
                                "type": "string",
                                "enum": [
                                    "build_today_schedule",
                                    "generate_route_refresh_tasks",
                                    "dispatch_daily_probe_tasks",
                                    "clear_daily_probe_status"
                                ]
                            }
                        }
                    },
                    "required": [
                        "disabledExecutors"
                    ]
                },
                "scheduler": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "pollIntervalMs": {
                            "type": "integer",
                            "minimum": 1000
                        },
                        "maxTasksPerQuery": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "idle": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "maxTasksPerTick": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "emaAlpha": {
                                    "type": "number",
                                    "exclusiveMinimum": 0,
                                    "maximum": 1
                                }
                            },
                            "required": [
                                "maxTasksPerTick",
                                "emaAlpha"
                            ]
                        }
                    },
                    "required": [
                        "pollIntervalMs",
                        "maxTasksPerQuery",
                        "idle"
                    ]
                }
            },
            "required": [
                "scheduler"
            ]
        },
        "quota": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "anonymousMaxTokens": {
                    "type": "integer",
                    "minimum": 1
                },
                "userMaxTokens": {
                    "type": "integer",
                    "minimum": 1
                },
                "refillAmount": {
                    "type": "integer",
                    "minimum": 1
                },
                "refillIntervalSeconds": {
                    "type": "integer",
                    "minimum": 1
                },
                "resetToMaxOnRestart": {
                    "type": "boolean"
                },
                "consumeTokens": {
                    "type": "boolean"
                }
            },
            "required": [
                "anonymousMaxTokens",
                "userMaxTokens",
                "refillAmount",
                "refillIntervalSeconds",
                "resetToMaxOnRestart",
                "consumeTokens"
            ]
        },
        "cost": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "fixed": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "health": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "authMe": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "authLogout": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "debugEchoError": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "authIssueApiKey": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "authListApiKeys": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "authRevokeApiKey": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "searchIndex": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "exportDaily": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "health",
                        "authMe",
                        "authLogout",
                        "debugEchoError",
                        "authIssueApiKey",
                        "authListApiKeys",
                        "authRevokeApiKey",
                        "searchIndex",
                        "exportDaily"
                    ]
                },
                "perRecord": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "historyEmu": {
                            "$ref": "#/definitions/perRecordRule"
                        },
                        "historyTrain": {
                            "$ref": "#/definitions/perRecordRule"
                        },
                        "recordsDaily": {
                            "$ref": "#/definitions/perRecordRule"
                        }
                    },
                    "required": [
                        "historyEmu",
                        "historyTrain",
                        "recordsDaily"
                    ]
                }
            },
            "required": [
                "fixed",
                "perRecord"
            ]
        }
    },
    "definitions": {
        "perRecordRule": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "unitCost": {
                    "type": "number",
                    "minimum": 0
                },
                "rounding": {
                    "type": "string",
                    "enum": [
                        "ceil"
                    ]
                }
            },
            "required": [
                "unitCost",
                "rounding"
            ]
        }
    },
    "required": [
        "spider",
        "data",
        "user",
        "api",
        "task",
        "quota",
        "cost"
    ]
}
